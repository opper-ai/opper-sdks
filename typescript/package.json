{
  "name": "opperai",
  "version": "4.0.0-beta.3",
  "description": "Opper TypeScript SDK — execute functions, stream results, and build AI agents.",
  "repository": {
    "type": "git",
    "url": "https://github.com/opper-ai/opper-sdks.git",
    "directory": "typescript"
  },
  "homepage": "https://github.com/opper-ai/opper-sdks/tree/main/typescript",
  "bugs": {
    "url": "https://github.com/opper-ai/opper-sdks/issues"
  },
  "publishConfig": {
    "tag": "beta"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "examples": "tsx examples/run-all.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "task-api",
    "sdk",
    "typescript",
    "llm",
    "starlark",
    "opper"
  ],
  "license": "MIT",
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18",
    "ws": "^8.20.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
