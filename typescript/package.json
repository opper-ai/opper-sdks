{
  "name": "task-api-sdk",
  "version": "3.0.0",
  "description": "TypeScript SDK for the Task API - Schema-driven generative API that uses Starlark scripts to orchestrate LLM-powered workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "task-api",
    "sdk",
    "typescript",
    "llm",
    "starlark",
    "opper"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
